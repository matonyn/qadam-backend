SECRET_KEY=change-this-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Supabase project URL (same as Next.js / Expo)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Publishable (anon) key — optional if you set SUPABASE_SECRET_KEY below
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Backend (required for seed on startup + most API writes): Secret / service_role key from
# Dashboard → Settings → API. The publishable key alone hits RLS and will fail inserts.
# Accepted names: SUPABASE_SECRET_KEY, SUPABASE_SERVICE_ROLE_KEY, or SERVICE_ROLE_KEY
# SUPABASE_SECRET_KEY=

# Smart Campus ML (optional)
# SENTIMENT_MODEL_PATH=
# CROWD_MODEL_PATH=

# 2GIS Routing API (optional; enables real street/pedestrian routing)
# Get key via https://platform.2gis.ru/
TWOGIS_API_KEY=

# Optional: required for POST /api/v1/maps/buildings/sync-from-2gis (imports NU catalog into `buildings`)
# Send the same value in header `X-Qadam-Sync-Key`.
# CAMPUS_2GIS_SYNC_SECRET=
